# LifeOS backend environment example
# Copie para .env localmente e preencha com suas próprias chaves.
FLASK_ENV=development
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

FIREBASE_CREDENTIALS=serviceAccountKey.json

GROQ_API_KEY=
AI_ONBOARDING_KEY=
AI_PLANNING_KEY=
AI_DAILY_KEY=

SECRET_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
